# Backend configuration
APP_ENV=development
LOG_LEVEL=INFO
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
PAGEINDEX_API_KEY=your-pageindex-api-key
PAGEINDEX_MODE=mcp
PAGEINDEX_POLL_ATTEMPTS=20
PAGEINDEX_POLL_INTERVAL_SECONDS=2

# Backend service
BACKEND_URL=http://localhost:8000

# Optional: storage location inside container
STORAGE_PATH=/app/shared

# Optional: maximum upload size in MB (default: 100)
MAX_UPLOAD_SIZE_MB=100
